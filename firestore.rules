rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /orders/{document} {
      allow read: if true;
      allow write: if true;
    }
    match /products/{document} {
      allow read: if true;
      allow write: if true;
    }
    match /settings/{document} {
      allow read: if true;
      allow write: if true;
    }
    match /reviews/{document} {
      allow read: if true;
      allow write: if true;
    }
  }
}
